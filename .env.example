# ============================================================
# LookForBest 生产环境变量模板
# 使用方式：cp .env.example .env 并填写实际值
# ⚠️  .env 文件已在 .gitignore 中，永远不要提交真实密钥到 Git
# ============================================================

# ---- 运行环境 ----
SPRING_PROFILES_ACTIVE=prod

# ---- 域名与 SSL ----
DOMAIN=yourdomain.com
SSL_EMAIL=admin@yourdomain.com

# ---- 数据库（MySQL）----
# 来源：docker-compose 自动创建，或手动在 MySQL 中创建 lookforbest 数据库
DB_USERNAME=lookforbest
# 必须修改：强密码（大小写+数字+特殊字符，16位以上）
DB_PASSWORD=CHANGE_ME_strong_db_password_here
# MySQL root 密码（与 DB_PASSWORD 不同）
DB_ROOT_PASSWORD=CHANGE_ME_root_db_password_here
# 完整 JDBC URL（docker-compose 环境默认不用改）
DB_URL=jdbc:mysql://mysql:3306/lookforbest?useUnicode=true&characterEncoding=utf8mb4&serverTimezone=UTC&allowPublicKeyRetrieval=true&useSSL=false

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
# 必须修改（留空则 Redis 不设密码，仅本地开发可以）
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# ---- JWT 认证 ----
# 必须修改：至少 32 个随机字符
# 生成命令: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_random_32plus_chars_jwt_secret

# ---- MinIO 对象存储（图片/文件上传）----
MINIO_ENDPOINT=http://minio:9000
# 必须修改
MINIO_ACCESS_KEY=CHANGE_ME_minio_access_key
MINIO_SECRET_KEY=CHANGE_ME_minio_secret_key_16plus
MINIO_BUCKET=lookforbest
STORAGE_TYPE=minio

# ---- CORS 跨域配置 ----
# 允许访问后端的前端域名，多个用逗号分隔
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# ---- 限流配置 ----
RATE_LIMIT_ENABLED=true
# 未登录 IP 每分钟最大请求数
RATE_LIMIT_DEFAULT=30
# 登录/auth 接口 IP 每分钟最大请求数
RATE_LIMIT_AUTH=20
# 已登录用户每分钟最大请求数（按 userId，多账号不叠加配额）
RATE_LIMIT_USER=20
# 注册接口 IP 每分钟最大请求数（防批量注册）
RATE_LIMIT_REGISTER=5
# 受信任的反向代理 IP（逗号分隔），仅来自这些 IP 才信任 X-Forwarded-For 头
RATE_LIMIT_TRUSTED_PROXIES=127.0.0.1,::1

# ---- 站点基础 URL ----
SITE_BASE_URL=https://yourdomain.com

# ---- 社交登录 OAuth ----
# Google OAuth（前端使用 Google Sign-In SDK 获取 idToken，无需后端 client_id）

# 微信小程序登录（在微信开放平台 → 小程序管理 → 设置 → 开发设置 获取）
WECHAT_MINIAPP_APP_ID=wx_your_miniapp_app_id
WECHAT_MINIAPP_APP_SECRET=your_miniapp_app_secret

# 微信网页扫码登录（在微信开放平台 → 网站应用 → 管理 获取）
WECHAT_WEB_APP_ID=wx_your_web_app_id
WECHAT_WEB_APP_SECRET=your_web_app_secret

# ---- Anthropic Claude AI（AI对话功能）----
# 申请地址：https://console.anthropic.com/
# 不填则 AI 对话功能不可用，其余功能不受影响
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME_your_anthropic_key
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Elasticsearch（全文搜索，可选）----
# 留空则搜索功能降级为 MySQL LIKE 查询
ELASTICSEARCH_URIS=http://elasticsearch:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_ENABLED=false

# ---- 推荐引擎（可选）----
# 指向 recommend/ 模块的 FastAPI 服务地址
RECOMMEND_URL=http://recommend:8000
RECOMMEND_ENABLED=false

# ---- 爬虫服务（可选）----
# 指向 scripts/spider/ 的爬虫 API 服务地址
CRAWLER_URL=http://crawler:8002

# ---- 爬虫检测与自动封禁 ----
ANTI_SCRAPE_ENABLED=true
# 检测时间窗口（分钟）
# ANTI_SCRAPE_WINDOW_MINUTES=5
# 窗口内列表接口调用上限（超过封禁1小时）
# ANTI_SCRAPE_LIST_THRESHOLD=10
# 窗口内详情接口调用上限（超过封禁1小时）
# ANTI_SCRAPE_DETAIL_THRESHOLD=30

# ---- Swagger API 文档（生产环境务必保持 false）----
# 开发环境可改为 true，通过 /swagger-ui.html 访问
SWAGGER_ENABLED=false

# ---- 后端服务端口 ----
PORT=8080
