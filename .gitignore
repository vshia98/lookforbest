# ============================================================
# LookForBest .gitignore
# ============================================================

# ---- Environment / Secrets ----
.env
.env.local
.env.*.local
*.key
*.pem
*.p12

# ---- macOS ----
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ---- Node.js (frontend / miniapp) ----
node_modules/
dist/
.npm
.eslintcache
.cache

# ---- Flutter / Dart ----
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
build/
*.iml
*.ipr
*.iws
.idea/

# ---- Java / Spring Boot ----
target/
*.class
*.jar
*.war
*.ear
*.log
.gradle/
gradle-app.setting
*.gradle
local.properties
.classpath
.project
.settings/

# ---- Python (recommend / crawler) ----
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.tox/
.venv/
venv/
env/
.Python
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- Docker ----
docker-volumes/
mysql-data/
redis-data/
elasticsearch-data/
minio-data/

# ---- IDE ----
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath

# ---- Logs ----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- OS ----
Thumbs.db
ehthumbs.db
Desktop.ini

# ---- Test / Coverage ----
coverage/
.nyc_output/
htmlcov/
.coverage
*.cover

# ---- Build artifacts ----
*.apk
*.ipa
*.aab
*.zip
*.tar.gz
